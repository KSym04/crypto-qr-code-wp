# Release exclude gate for Crypto QR Code WP (consumed by scripts/build-plugin-release.sh).
# Keep the WordPress.org zip dev-free, AI-free, and strategy-free.
# NOTE: assets/js/qrcode.min.js IS a runtime dependency and ships with the plugin.
# Mirrors the FeedProof for WooCommerce / Zen Addons release conventions.

# This file itself
.distignore

# Release build artifacts (never ship the zip inside the zip)
for-release/

# VCS / dev tooling
.git
.gitignore
.gitattributes
.editorconfig
.travis.yml
.circleci/
.github/
node_modules/

# AI assistant, strategy, and planning docs
CLAUDE.md
WORKSPACE-SETUP.md
AGENTS.md
MILESTONE-*.md
ROADMAP-*.md
*-strategy.md
*strategy*.md
*.prompt.md
*.instructions.md
*.agent.md
.cursor/
.cursorrules
.aider*
.claude/

# Dev documentation (WordPress.org uses readme.txt, not these)
README.md
readme.md
docs/

# PHP / JS tooling and manifests
composer.json
composer.lock
phpcs.xml
phpcs.xml.dist
phpstan.neon
phpunit.xml
phpunit.xml.dist
package.json
package-lock.json
yarn.lock
gulpfile.js

# Build artifacts and source maps
*.css.map
*.scss

# Dev scripts, tests, build, logs
scripts/
tests/
Makefile
*.sh
*.log

# Screenshots are uploaded to the SVN assets/ directory, not shipped in the plugin zip
screenshots/
